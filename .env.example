# .env — SECRETS and identity only. Copy to .env and fill in.
# Every key is prefixed BBAGENT_ when set here or in the environment.
# Non-secret TUNING KNOBS (scouting weight, trade thresholds, slot ids, etc.)
# live in bbagent.config.json instead — that file is safe to commit; this one
# is gitignored. Resolution order, highest priority first:
#   BBAGENT_<KEY> env var  >  bbagent.local.json  >  bbagent.config.json  >  default

# --- required: ESPN auth + league identity ----------------------------------
# Grab the cookies from a logged-in browser: DevTools > Application > Cookies on
# fantasy.espn.com. SWID includes the curly braces. LEAGUE_ID is the number in
# your league URL — kept here (not committed) so a public repo doesn't reveal it.
BBAGENT_ESPN_S2=PASTE_ESPN_S2_COOKIE
BBAGENT_SWID={PASTE-SWID-WITH-BRACES}
BBAGENT_LEAGUE_ID=PASTE_LEAGUE_ID
# Optional: pin your team (otherwise auto-resolved from SWID):
# BBAGENT_AGENT_TEAM_ID=

# --- email sending secret (optional) ----------------------------------------
# SMTP host/from/to are not secret and can go in bbagent.config.json; only the
# password is a secret and belongs here. For Gmail use an App Password.
# BBAGENT_SMTP_PASS=your-app-password-or-api-key

# --- Anthropic key (only for the `run` LLM loop) ----------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# --- Claude Code in the container (only for the 3.2 run mode) ----------------
# Headless `claude` has no interactive login. Pick ONE:
#  - subscription (no API credits): run `claude setup-token` on a logged-in
#    machine and paste the token here;
#  - or just set ANTHROPIC_API_KEY above (bills credits).
# CLAUDE_CODE_OAUTH_TOKEN=

# Tip: `python espn_agent.py config` prints every resolved value (secrets
# masked) so you can confirm what took effect and from where.
